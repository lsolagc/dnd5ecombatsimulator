<div id="<%= dom_id base_combatant %>">
  <p>
    <h1>
      <%= base_combatant.name %>
    </h1>
  </p>

  <p>
    <strong>
      <%= BaseCombatant.human_attribute_name('armor_class').capitalize %>
    </strong>
    <%= base_combatant.armor_class %>
  </p>

  <p>
    <strong>
      <%= BaseCombatant.human_attribute_name('hit_die').capitalize %>
    </strong>
    <%= base_combatant.hit_die %>
