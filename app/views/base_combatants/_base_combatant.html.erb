  <p>
    <strong>
      <%= BaseCombatant.human_attribute_name('hitpoints').capitalize %>
    </strong>
    <%= base_combatant.hitpoints %>
  </p>

  <p>
    <strong>
      <%= BaseCombatant.human_attribute_name('proficiency_bonus').capitalize %>
