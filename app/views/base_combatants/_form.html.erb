
<%= simple_form_for(@base_combatant) do |f| %>
  <%= f.error_notification %>
  <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

  <div class="form-inputs">
    <%= f.input :name %>
    <%= f.input :armor_class %>
    <%= f.input :hit_die %>
    <%= f.input :hit_dice_number %>
    <%= f.input :hitpoints %>
    <%= f.input :proficiency_bonus %>
    <%= f.input :strength %>
    <%= f.input :dexterity %>
    <%= f.input :constitution %>
    <%= f.input :intelligence %>
    <%= f.input :wisdom %>
    <%= f.input :charisma %>
    <%= f.input :skills %>
  </div>

  <div class="form-actions">
    <%= f.button :submit %>
  </div>
<% end %>
